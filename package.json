{
  "name": "virtutrade",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix ./server",
    "build": "npm exec -- vite build",
    "lint": "eslint .",
    "preview": "npm exec -- vite preview",
    "start": "npm exec -- vite",
    "server": "cd server && npm start",
    "dev": "npm exec -- concurrently -n \"client,server\" -c \"bgBlue,bgYellow\" \"npm run start\" \"npm run server\"",
    "zap:baseline": "docker run --rm -t -v \"$PWD:/zap/wrk/:rw\" ghcr.io/zaproxy/zaproxy:stable zap-baseline.py -t \"${ZAP_TARGET:-http://host.docker.internal:3000}\" -c zap-rules.conf -I -r zap-report.html -J zap-report.json -w zap-report.md",
    "zap:full": "docker run --rm -t -v \"$PWD:/zap/wrk/:rw\" ghcr.io/zaproxy/zaproxy:stable zap-full-scan.py -t \"${ZAP_TARGET:-http://host.docker.internal:3000}\" -c zap-rules.conf -I -r zap-full-report.html -J zap-full-report.json -w zap-full-report.md",
    "zap:ci": "docker run --rm -t -v \"$PWD:/zap/wrk/:rw\" ghcr.io/zaproxy/zaproxy:stable zap-baseline.py -t \"${ZAP_TARGET:-http://host.docker.internal:3000}\" -c zap-rules.conf -m 5"
  },
  "dependencies": {
    "@heroicons/react": "^1.0.6",
    "@react-oauth/google": "^0.12.1",
    "@tailwindcss/vite": "^4.0.13",
    "axios": "^1.15.2",
    "chart.js": "^4.4.9",
    "concurrently": "^9.1.2",
    "framer-motion": "^12.5.0",
    "lightweight-charts": "^5.0.5",
    "lucide-react": "^0.485.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.14.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "vite": "^6.4.2"
  }
}
