# Copy to .env in this folder (server/) and fill in values.

# MongoDB (required)
DATABASE_URL=mongodb+srv://rowagrawal:MS0V4jXipuUwaA4X@cluster0.fzv3d.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Auth (required for JWT)
JWT_SECRET=VirtuTrade

# Frontend origin for CORS and cookies (match your Vite URL)
FRONTEND_URL=http://localhost:5173

# In the project root .env, set VITE_APP_WEB_URL to this API origin, e.g.:
#   VITE_APP_WEB_URL=http://localhost:4000
# (same host/port as this server, unless you override PORT below)

# Optional
PORT=4000
# Set true in production to reject plaintext HTTP requests.
FORCE_HTTPS=false

# Moesif API analytics (optional — omit to disable middleware)
# MOESIF_APPLICATION_ID=
# MOESIF_LOG_BODY=false

# Email (password reset / OTP — set if you use mail features)
# MAIL_HOST=
# MAIL_USER=
# MAIL_PASS=
